# Lite Hosting Panel — environment secrets template
#
# Copy this file to /usr/local/litepanel/.env and fill in real values.
# IMPORTANT: restrict permissions immediately after creation:
#   chmod 600 /usr/local/litepanel/.env
#   chown root:root /usr/local/litepanel/.env
#
# Generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Generate a Django secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

FERNET_KEY=<replace-with-fernet-key>
SECRET_KEY=<replace-with-django-secret-key>
